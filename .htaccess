<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^assets/ - [L]
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Powered-By "MROSC"

  # Always revalidate HTML so the root route does not stay on an old build.
  <FilesMatch "^(?:index\.html)?$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </FilesMatch>

  # Keep hashed assets cacheable for faster repeat visits.
  <FilesMatch "\.(?:js|css|map|json|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
</IfModule>
